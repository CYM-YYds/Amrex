#!/usr/bin/env bash
REAL_GIT_BIN="${REAL_GIT:-$(command -v git || echo /usr/bin/git)}"
subcmd="$1"
case "$subcmd" in
    describe|rev-parse)
        # 静默 stderr，若失败则返回空串并退出 0，避免 make 输出 fatal 噪声
        out="$($REAL_GIT_BIN "$@" 2>/dev/null || true)"
        if [ -n "$out" ]; then
            printf "%s\n" "$out"
            exit 0
        else
            exit 0
        fi
        ;;
    *)
        exec "$REAL_GIT_BIN" "$@"
        ;;
esac
